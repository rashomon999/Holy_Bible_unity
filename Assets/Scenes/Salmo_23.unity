  input8: {fileID: 1564398228}
  input9: {fileID: 166692353}
  input10: {fileID: 1506935601}
  input11: {fileID: 294675654}
  input12: {fileID: 2135726176}
  input13: {fileID: 1704862594}
  input14: {fileID: 678141847}
  input15: {fileID: 1523689274}
  input16: {fileID: 0}
  input17: {fileID: 0}
  input18: {fileID: 0}
  input19: {fileID: 0}
  resultadoText: {fileID: 0}
  respuestaCorrecta1: "Jehov\xE1 es mi pastor"
  respuestaCorrecta2: "nada me faltar\xE1"
  respuestaCorrecta3: "En lugares de delicados pastos me har\xE1 descansar"
  respuestaCorrecta4: "Junto a aguas de reposo me pastorear\xE1"
  respuestaCorrecta5: "Confortar\xE1 mi alma"
  respuestaCorrecta6: Me guiara por sendas de justicia por amor a su nombre
  respuestaCorrecta7: Aunque ande en valle de sombra de muerte
  respuestaCorrecta8: "No temer\xE9 mal alguno"
  respuestaCorrecta9: "porque t\xFA estar\xE1s conmigo"
  respuestaCorrecta10: "Tu vara y tu vallado me fundir\xE1n aliento"
  respuestaCorrecta11: "Aderezas mesa delante de m\xED en presencia de mis angustiadores"
  respuestaCorrecta12: Unges mi cabeza con aceite
  respuestaCorrecta13: " mi copa est\xE1 rebosando"
  respuestaCorrecta14: "Ciertamente el bien y la misericordia me seguir\xE1n todos
    los d\xEDas de mi vida"
  respuestaCorrecta15: "Y en la casa de Jehov\xE1 morar\xE9 por largos d\xEDas"
  respuestaCorrecta16: Respuesta16
  respuestaCorrecta17: Respuesta17
  respuestaCorrecta18: Respuesta18
  respuestaCorrecta19: Respuesta19
